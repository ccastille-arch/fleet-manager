# ── App ────────────────────────────────────────────────────────────────────
APP_NAME="Fleet Manager"
APP_URL="https://your-fleet-app.railway.app"
PORT=3002
NODE_ENV=production

# ── Secrets ─────────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-long-random-string

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=
DB_PATH=./fleet.db

# ── SSO Integration (from Ask Cody admin panel → OAuth Clients) ─────────────
SSO_URL=https://askcody.up.railway.app
SSO_CLIENT_ID=client_your_client_id_here
SSO_CLIENT_SECRET=your_client_secret_here

# ── Local dev bypass (set true to skip SSO, use simple local auth) ──────────
LOCAL_AUTH=false
LOCAL_USERNAME=admin
LOCAL_PASSWORD=admin
